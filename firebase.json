{
  "hosting": {
    "public": "./",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/.vscode/**",
      "**/.git/**",
      "**/.github/**",
      "**/backend/**"
    ]
  },
  "functions": {
    "source": "backend"
  },
  "rewrites": [
    {
      "source": "/api/**",
      "function": "generate_content"
    }
  ]
}
